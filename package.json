{
  "name": "cyperux",
  "version": "0.0.0",
  "private": true,
  "description": "Cyperux",
  "license": "UNLICENSED",
  "packageManager": "npm@11.7.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "e2e": "playwright test --ui --config src/test/webapp/e2e/playwright.config.ts",
    "e2e:headless": "playwright test --config src/test/webapp/e2e/playwright.config.ts",
    "test:component": "start-server-and-test dev http://localhost:9000 'playwright test --ui --config src/test/webapp/component/playwright.config.ts'",
    "test:component:headless": "start-server-and-test dev http://localhost:9000 'playwright test --config src/test/webapp/component/playwright.config.ts'",
    "dev": "npm-run-all --parallel dev:*",
    "dev:vite": "vite",
    "build": "npm-run-all build:*",
    "build:tsc": "tsc -b",
    "build:vite": "vite build --emptyOutDir",
    "preview": "vite preview",
    "start": "vite",
    "lint": "eslint .",
    "test": "npm run watch:test",
    "test:coverage": "vitest run --coverage",
    "watch": "npm-run-all --parallel watch:*",
    "watch:tsc": "tsc --noEmit --watch",
    "watch:test": "vitest --",
    "prettier:check": "prettier --check .",
    "prettier:format": "prettier --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "1.57.0",
    "start-server-and-test": "2.1.3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.1",
    "@types/node": "24.10.4",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@tsconfig/vite-react": "7.0.2",
    "@vitejs/plugin-react": "5.1.2",
    "eslint-plugin-react": "7.37.5",
    "jsdom": "27.3.0",
    "vite": "7.3.0",
    "typescript": "5.9.3",
    "@typescript-eslint/eslint-plugin": "8.50.0",
    "@typescript-eslint/parser": "8.50.0",
    "@vitest/coverage-istanbul": "4.0.16",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "@eslint/js": "9.39.2",
    "globals": "16.5.0",
    "npm-run-all2": "8.0.4",
    "typescript-eslint": "8.50.0",
    "vite-tsconfig-paths": "6.0.3",
    "vitest": "4.0.16",
    "vitest-sonar-reporter": "3.0.0",
    "@prettier/plugin-xml": "3.4.2",
    "prettier": "3.7.4",
    "prettier-plugin-gherkin": "3.1.3",
    "prettier-plugin-java": "2.7.7",
    "prettier-plugin-organize-imports": "4.3.0",
    "prettier-plugin-packagejson": "2.5.20",
    "husky": "9.1.7",
    "lint-staged": "16.2.7"
  },
  "type": "module",
  "dependencies": {
    "i18next": "25.7.3",
    "i18next-browser-languagedetector": "8.2.0",
    "i18next-http-backend": "3.0.2",
    "react-i18next": "16.5.0",
    "arch-unit-ts": "1.0.9",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "piqure": "2.1.2"
  }
}
