+// Camera controller
+function CameraController({ resetTrigger }: { resetTrigger: number }) {
+  const { camera } = useThree()
+  
+  useMemo(() => {
+    if (resetTrigger > 0) {
+      camera.position.set(18, 14, 18)
+      camera.lookAt(0, 3, 0)
+    }
+  }, [resetTrigger, camera])
+  
+  return null
+}
