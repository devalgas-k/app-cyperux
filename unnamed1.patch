+        <div className="absolute bottom-4 left-4 flex items-center gap-2 rounded-lg border bg-card/90 p-2 backdrop-blur">
+          <Button
+            size="sm"
+            variant="ghost"
+            onClick={() => setRotation((prev) => prev - 45)}
+          >
+            <RotateCcw className="h-4 w-4" />
